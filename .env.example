# Local and production environment variables for ROVEXO
# Use placeholder values only. Replace with real values in your local .env.local or deployment environment.

# App identity and metadata (required in production — must match your Vercel primary domain)
NEXT_PUBLIC_APP_URL=https://www.rovexo.co.uk
NEXT_PUBLIC_SITE_URL=https://www.rovexo.co.uk
NODE_ENV=production
VERCEL_URL=rovexo.vercel.app

# Supabase — canonical names (set these in .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<key>
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<key>

# Legacy aliases (optional fallbacks — do not duplicate canonical values)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_<key>
SUPABASE_SECRET_KEY=sb_secret_<key>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>

# Supabase CLI migration automation (local only — never commit real values)
SUPABASE_ACCESS_TOKEN=sbp_<personal-access-token>
SUPABASE_DB_PASSWORD=<database-password>

# Stripe payments and webhook signing
STRIPE_SECRET_KEY=sk_test_<key>
STRIPE_WEBHOOK_SECRET=whsec_<key>

# Bank account details encryption (AES-256-GCM). REQUIRED in production so that
# stored sort codes / account numbers are encrypted at the column level.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# (32-byte key, base64 or 64-char hex). If unset, details are stored unencrypted (dev only).
BANK_DETAILS_ENCRYPTION_KEY=<base64-32-byte-key>

# Transactional email (Resend)
RESEND_API_KEY=re_<key>
EMAIL_FROM="ROVEXO <support@rovexo.co.uk>"

# Rate limiting / Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://<account>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# Cron authentication secret for scheduled maintenance and cleanup
CRON_SECRET=<secure-random-string>

# Shipping — GoShippo / Shippo (server-side only; never expose to the frontend)
SHIPPO_API_KEY=shippo_<key>
# Optional webhook verification token for POST /api/webhooks/shippo
SHIPPO_WEBHOOK_TOKEN=<secure-random-string>

# Shipping — Parcel2Go (server-side only; never expose to the frontend)
# Production (live):
# PARCEL2GO_AUTH_URL=https://www.parcel2go.com/auth
# PARCEL2GO_API_URL=https://www.parcel2go.com
# Sandbox:
PARCEL2GO_CLIENT_ID=<client-id>
PARCEL2GO_CLIENT_SECRET=<client-secret>
PARCEL2GO_AUTH_URL=https://sandbox.parcel2go.com/auth
PARCEL2GO_API_URL=https://sandbox.parcel2go.com
# Optional webhook signing secret for Parcel2Go webhooks
PARCEL2GO_WEBHOOK_SECRET=<secure-random-string>

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-RNEMD5BT0S
NEXT_PUBLIC_GA_DEBUG=false
# GA4 Data API (optional — live countries in Super Admin)
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_EMAIL=
GA4_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional AI Camera / OpenAI
OPENAI_API_KEY=sk_<key>
OPENAI_VISION_MODEL=gpt-4o-mini
AI_CAMERA_VISION_MOCK=false

# Playwright / local test overrides
# PLAYWRIGHT_BASE_URL=http://localhost:3010
# PLAYWRIGHT_PORT=3010
# PLAYWRIGHT_SKIP_WEBSERVER=true

# Demo / UAT environment (real Supabase auth + data — NOT production)
# DEMO_SEED_ENABLED=1
# DEMO_ALLOW_PRODUCTION=1
# DEMO_SEED_PASSWORD=RovexoDemo2026!
# ROVEXO_HOMEPAGE_CLOSED_BETA=1
# NEXT_PUBLIC_ROVEXO_HOMEPAGE_CLOSED_BETA=1
# ROVEXO_HOMEPAGE_DEMO=1
# NEXT_PUBLIC_ROVEXO_HOMEPAGE_DEMO=1
# ROVEXO_APPROVED_TESTER_EMAILS=tester@example.com
# ROVEXO_HOMEPAGE_ELIGIBILITY_LOG=1

# Staff PII encryption (Super Admin staff profiles — required in production)
# STAFF_PII_SECRET=<32+ char secret>

# Staff Enterprise web portal (canonical: https://staff.rovexo.co.uk)
# NEXT_PUBLIC_STAFF_URL=https://staff.rovexo.co.uk
# STAFF_HOSTS=staff.rovexo.co.uk,staff.localhost

# Native staff push (Android FCM / iOS APNs)
# FCM_SERVER_KEY=<firebase-server-key>
# APNS_KEY_ID=<apns-key-id>
# APNS_TEAM_ID=<apple-team-id>
# APNS_BUNDLE_ID=co.uk.rovexo.staff

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@rovexo.co.uk

# Tier 2A marketplace connectors (optional — server-side defaults apply)
# ETSY_API_KEYSTRING=<etsy-api-keystring>
# EBAY_API_BASE_URL=https://api.ebay.com
# ETSY_API_BASE_URL=https://openapi.etsy.com

# Bring Your Item OAuth (server-side only — never expose to the frontend)
# Release gate — marketplace core v1.0 is independent; enable BYI only after PRODUCTION READY certification.
# NEXT_PUBLIC_BRING_YOUR_ITEM_ENABLED=false
# BRING_YOUR_ITEM_ENABLED=false
# CONNECTOR_CREDENTIALS_SECRET=<base64-32-byte-key>
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# eBay OAuth redirect: full callback URL or eBay RuName (must match developer portal)
# EBAY_REDIRECT_URI=https://www.rovexo.co.uk/api/seller/marketplace/oauth/ebay/callback
# EBAY_RUNAME=
# ETSY_CLIENT_ID=
# ETSY_CLIENT_SECRET=
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=
