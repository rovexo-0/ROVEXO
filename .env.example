# Local and production environment variables for ROVEXO
# Use placeholder values only. Replace with real values in your local .env.local or deployment environment.

# App identity and metadata (required in production — must match your Vercel primary domain)
NEXT_PUBLIC_APP_URL=https://www.rovexo.co.uk
NEXT_PUBLIC_SITE_URL=https://www.rovexo.co.uk
NODE_ENV=production
VERCEL_URL=rovexo.vercel.app

# Supabase — canonical names (set these in .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<key>
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<key>

# Legacy aliases (optional fallbacks — do not duplicate canonical values)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_<key>
SUPABASE_SECRET_KEY=sb_secret_<key>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<key>

# Supabase CLI migration automation (local only — never commit real values)
SUPABASE_ACCESS_TOKEN=sbp_<personal-access-token>
SUPABASE_DB_PASSWORD=<database-password>

# Stripe payments and webhook signing
STRIPE_SECRET_KEY=sk_test_<key>
STRIPE_WEBHOOK_SECRET=whsec_<key>

# Transactional email (Resend)
RESEND_API_KEY=re_<key>
EMAIL_FROM="ROVEXO <support@rovexo.co.uk>"

# Rate limiting / Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://<account>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# Cron authentication secret for scheduled maintenance and cleanup
CRON_SECRET=<secure-random-string>

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-RNEMD5BT0S
NEXT_PUBLIC_GA_DEBUG=false
# GA4 Data API (optional — live countries in Super Admin)
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_EMAIL=
GA4_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional AI Camera / OpenAI
OPENAI_API_KEY=sk_<key>
OPENAI_VISION_MODEL=gpt-4o-mini
AI_CAMERA_VISION_MOCK=false

# Playwright / local test overrides
# PLAYWRIGHT_BASE_URL=http://localhost:3010
# PLAYWRIGHT_PORT=3010
# PLAYWRIGHT_SKIP_WEBSERVER=true

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@rovexo.co.uk

# Tier 2A marketplace connectors (optional — server-side defaults apply)
# ETSY_API_KEYSTRING=<etsy-api-keystring>
# EBAY_API_BASE_URL=https://api.ebay.com
# ETSY_API_BASE_URL=https://openapi.etsy.com
