{
  "name": "rovexo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "verify:env": "npx tsx scripts/verify-env.ts",
    "verify:production": "node scripts/verify-production.mjs",
    "verify:dev-preview": "node scripts/verify-dev-preview.mjs",
    "db:migrate": "node scripts/supabase-migrate-workflow.mjs",
    "db:republish-homepage": "npx tsx scripts/republish-homepage-launch-defaults.ts",
    "db:push": "supabase db push --linked --yes",
    "db:idempotent": "node scripts/refactor-migrations-idempotent.mjs",
    "test": "vitest run",
    "test:ci": "vitest run --exclude tests/supabase.integration.test.ts --exclude tests/category-detection-step7.test.ts --exclude tests/suggest-category-from-title.test.ts",
    "test:database": "vitest run tests/supabase.integration.test.ts",
    "test:migrations": "node scripts/validate-migrations.mjs",
    "test:seo-regression": "vitest run tests/seo-engine-v4.test.ts tests/seo-engine-v3.test.ts tests/seo-engine-v2.test.ts tests/seo-engine-v1.test.ts tests/phase7-seo.test.ts",
    "test:organic-growth": "vitest run tests/organic-growth-engine-v1.test.ts",
    "test:marketplace-intelligence": "vitest run tests/marketplace-intelligence-v1.test.ts",
    "test:marketplace-os": "vitest run tests/marketplace-os-v1.test.ts",
    "test:category": "vitest run tests/category-detection-step7.test.ts tests/suggest-category-from-title.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:certification:core": "node scripts/run-playwright.mjs e2e/full-demo-certification.spec.ts e2e/accessibility.spec.ts e2e/commerce-canonical.spec.ts e2e/messages-notifications-v1.spec.ts e2e/listing-lifecycle-certification.spec.ts --project=chromium",
    "test:e2e:certification:responsive": "node scripts/run-playwright.mjs e2e/responsive.spec.ts e2e/welcome-v2.spec.ts --project=chromium --project=iphone-safari --project=iphone-chrome --project=chrome-android --project=samsung-internet --project=tablet-ipad-portrait --project=desktop-wide",
    "test:e2e:certification": "npm run test:e2e:certification:core && npm run test:e2e:certification:responsive",
    "test:e2e:install": "playwright install",
    "test:e2e:install:chromium": "node scripts/install-playwright-chromium.mjs",
    "test:e2e:android-sell": "playwright test e2e/sell-android.spec.ts --project=android-chromium",
    "generate:brand": "node scripts/generate-brand-assets.mjs",
    "generate:icons": "node scripts/generate-rovexo-glass-icons.mjs",
    "generate:category-assets": "node scripts/generate-home-category-icons.mjs",
    "verify:category-assets": "node scripts/verify-category-premium-assets.mjs",
    "generate:hero-campaigns": "node scripts/generate-hero-campaign-sources.mjs && node scripts/generate-hero-campaigns.mjs",
    "verify:hero-campaigns": "node scripts/verify-hero-campaigns.mjs",
    "verify:assets": "npx tsx scripts/validate-production-assets.ts",
    "seed:demo": "npx tsx scripts/seed-demo-environment.ts",
    "verify:demo": "npx tsx scripts/verify-demo-environment.ts",
    "certify:full-demo": "npx tsx scripts/certify-full-demo.ts",
    "certify:full-demo:live": "npx tsx scripts/verify-full-demo-live.ts",
    "certify:deployment": "npx tsx scripts/certify-deployment.ts",
    "test:full-demo-contracts": "vitest run tests/full-demo-certification.test.ts tests/auth-startup-canonical.test.ts tests/auth-guest-entry-v1.test.ts tests/auth-splash-v1.test.ts tests/auth-welcome-v1.test.ts tests/launch-certification-master.test.ts tests/launch-certification-mode.test.ts",
    "certify:predeploy": "npm run typecheck && npm run lint && npm run test:ci && npm run test:migrations && npm run certify:full-demo && npm run certify:deployment && npm run build:production && DEMO_SEED_ENABLED=1 npm run seed:demo && npm run certify:full-demo:live && npm run test:database && npm run test:e2e:install:chromium && npm run test:e2e:certification && npm run certify:full-demo:live",
    "build:production": "next build",
    "predeploy:private": "npm run certify:predeploy",
    "deploy:private": "npx vercel deploy --yes",
    "cleanup:homepage-demo": "npx tsx scripts/cleanup-homepage-demo-data.ts",
    "marketplace:reset": "npx tsx scripts/marketplace-reset.ts",
    "audit:homepage-images": "npx tsx scripts/audit-homepage-images.ts",
    "restore:super-admin": "npx tsx scripts/restore-super-admin-access.ts",
    "certify:staff-enterprise": "npx tsx scripts/certify-staff-enterprise.ts",
    "staff:native:install": "npm install --prefix apps/rovexo-staff",
    "staff:native:sync": "npm run staff:native:install && npm --prefix apps/rovexo-staff run sync",
    "staff:build:android:apk": "npm --prefix apps/rovexo-staff run build:android:apk",
    "staff:build:android:aab": "npm --prefix apps/rovexo-staff run build:android:aab",
    "staff:build:ios": "npm --prefix apps/rovexo-staff run build:ios",
    "staff:build:windows": "npm --prefix apps/rovexo-staff run build:windows",
    "import:premium-assets": "node scripts/import-premium-photo-sources.mjs && node scripts/import-premium-empty-states.mjs",
    "generate:premium-assets": "node scripts/generate-production-from-sources.mjs && node scripts/generate-empty-state-assets.mjs",
    "prebuild": "npm run verify:assets && npm run typecheck && npm run lint && npm run test:full-demo-contracts && npm run certify:full-demo"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@next/third-parties": "16.2.9",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "browser-image-compression": "^2.0.2",
    "fast-xml-parser": "^5.9.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.511.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "server-only": "^0.0.1",
    "stripe": "^18.5.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.55.0",
    "@sparticuz/chromium": "^143.0.4",
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
