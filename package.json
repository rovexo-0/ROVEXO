{
  "name": "rovexo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "verify:env": "npx tsx scripts/verify-env.ts",
    "verify:production": "node scripts/verify-production.mjs",
    "db:migrate": "node scripts/supabase-migrate-workflow.mjs",
    "db:republish-homepage": "npx tsx scripts/republish-homepage-launch-defaults.ts",
    "db:push": "supabase db push --linked --yes",
    "db:idempotent": "node scripts/refactor-migrations-idempotent.mjs",
    "test": "vitest run",
    "test:ci": "vitest run --exclude tests/supabase.integration.test.ts --exclude tests/category-detection-step7.test.ts --exclude tests/suggest-category-from-title.test.ts",
    "test:category": "vitest run tests/category-detection-step7.test.ts tests/suggest-category-from-title.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install",
    "test:e2e:android-sell": "playwright test e2e/sell-android.spec.ts --project=android-chromium",
    "generate:brand": "node scripts/generate-brand-assets.mjs",
    "generate:icons": "node scripts/generate-rovexo-glass-icons.mjs",
    "generate:category-assets": "node scripts/generate-home-category-icons.mjs",
    "verify:category-assets": "node scripts/verify-category-premium-assets.mjs",
    "generate:hero-campaigns": "node scripts/generate-hero-campaign-sources.mjs && node scripts/generate-hero-campaigns.mjs",
    "verify:hero-campaigns": "node scripts/verify-hero-campaigns.mjs",
    "verify:assets": "npx tsx scripts/validate-production-assets.ts",
    "import:premium-assets": "node scripts/import-premium-photo-sources.mjs && node scripts/import-premium-empty-states.mjs",
    "generate:premium-assets": "node scripts/generate-production-from-sources.mjs && node scripts/generate-empty-state-assets.mjs",
    "prebuild": "npm run verify:assets"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@next/third-parties": "16.2.9",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "browser-image-compression": "^2.0.2",
    "fast-xml-parser": "^5.9.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.511.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "server-only": "^0.0.1",
    "stripe": "^18.5.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
