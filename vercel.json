{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "*": false,
      "main": true,
      "develop": true
    }
  },
  "buildCommand": "npm run certify:predeploy",
  "crons": [
    {
      "path": "/api/cron/maintenance",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/orders/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/migration/process",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/migration/publish",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/shipping/tracking",
      "schedule": "0 2 * * *"
    }
  ]
}
